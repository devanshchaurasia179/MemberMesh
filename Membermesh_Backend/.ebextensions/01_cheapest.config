option_settings:
  # Use SingleInstance (no load balancer, no NAT gateway)
  aws:elasticbeanstalk:environment:
    EnvironmentType: SingleInstance

  # Cheapest instance type (free-tier eligible)
  aws:autoscaling:launchconfiguration:
    InstanceType: t3.micro

  # Disable enhanced health reporting (uses basic = free)
  aws:elasticbeanstalk:healthreporting:system:
    SystemType: basic

  # Minimal deployment settings
  aws:elasticbeanstalk:command:
    DeploymentPolicy: AllAtOnce
    BatchSizeType: Percentage
    BatchSize: "100"

  # Disable managed platform updates (saves cost)
  aws:elasticbeanstalk:managedactions:
    ManagedActionsEnabled: false

  # Disable log streaming to CloudWatch (saves cost)
  aws:elasticbeanstalk:cloudwatch:logs:
    StreamLogs: false

  # Disable X-Ray tracing (saves cost)
  aws:elasticbeanstalk:xray:
    XRayEnabled: false
